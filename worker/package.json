{
  "name": "room-reservation-worker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist --env uat",
    "check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:postgres": "vitest run --config vitest.postgres.config.ts",
    "test:isolated-postgres": "node scripts/run-isolated-postgres.mjs",
    "test:local-e2e": "node scripts/run-local-e2e.mjs",
    "test:uat-e2e": "node scripts/run-uat-e2e.mjs",
    "migrate": "tsx scripts/migrate.ts",
    "uat:prepare": "tsx scripts/prepare-uat.ts",
    "artifact:manifest": "node scripts/artifact-manifest.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "hono": "4.12.31"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "@types/node": "24.0.15",
    "@types/pg": "8.20.0",
    "node-pg-migrate": "9.0.0",
    "pg": "8.22.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
